# ==================================================================
# .env — Instanz-spezifische Konfiguration (NICHT committen!)
# Kopiere diese Datei zu ".env" und passe die Werte pro Instanz an.
# Wird von app.py via python-dotenv (load_dotenv) geladen.
# ==================================================================

# --- Server ---
# Port, auf dem die App hört (DEV: 5002, PROD: 5001)
FLASK_PORT=5002
# Debug-/Reloader-Modus: 1 = an (DEV), 0 = aus (PROD)
FLASK_DEBUG=1

# --- Datenbank ---
# Voller SQLAlchemy-URI, ZWINGEND als ABSOLUTER Pfad angeben.
# Warum absolut: ein relativer Pfad (sqlite:///database/whs_dev.db) wird gegen
# das aktuelle Arbeitsverzeichnis aufgeloest. Startet die App, ein Test oder ein
# Skript aus einem anderen cwd, entsteht/oeffnet sich eine falsche DB-Datei —
# im schlimmsten Fall eine leere Schatten-DB neben der echten. Absolut = eindeutig.
# Ohne diese Variable faellt config.py auf die DEV-DB zurueck und warnt auf stderr.
# Windows-SQLite-Absolut-URI: sqlite:/// + Laufwerk mit Forward-Slashes.
# DEV:
DATABASE_URL=sqlite:///C:/inetpub/whs_app_dev/database/whs_dev.db
# PROD (Dienst WHSApp): sqlite:///C:/inetpub/whs_app_prod_neu/database/whs.db

# --- Sicherheit ---
# Session-/CSRF-Schlüssel. In PROD zwingend einen eigenen, geheimen Wert setzen!
SECRET_KEY=dev-secret-key-change-me

# --- Optional (config.py) ---
# Log-Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Maximale Upload-Größe in MB
MAX_CONTENT_LENGTH_MB=16

# ------------------------------------------------------------------
# Beispiel PROD-.env (bzw. NSSM-Environment des Dienstes WHSApp):
#   FLASK_PORT=5001
#   FLASK_DEBUG=0
#   DATABASE_URL=sqlite:///C:/inetpub/whs_app_prod_neu/database/whs.db
#   SECRET_KEY=<eigener geheimer Wert>
# ------------------------------------------------------------------
